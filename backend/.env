###############################################
# ENVIRONMENT CONFIGURATION FILE (.env)
# ---------------------------------------------
# This file stores sensitive configuration values
# for the backend service, including:
# - Database connection credentials
# - Server port
#
# IMPORTANT:
# Never commit this file to GitHub or share it publicly.
# Use strong passwords for all secrets.
# In production, always override these values using
# secure environment variables (Docker, CI/CD, PM2, etc.)
###############################################


###############################################
# DATABASE CONFIGURATION
# Used by the backend to connect to the MariaDB/MySQL database.
#
# DB_HOST      → Database server hostname or IP.
# DB_USER      → MySQL/MariaDB username.
# DB_PASSWORD  → Password for the database user.
# DB_NAME      → Name of the database schema to use.
###############################################
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=Jason1911!     # Replace with a secure password in production
DB_NAME=tarafisdb


###############################################
# SERVER CONFIGURATION
# PORT → Port number on which the Express server runs.
###############################################
PORT=3000

CORS_ORIGIN=http://localhost:3000,https://tarafis.com
JWT_SECRET=8039e864ff0988a4f7c92877b5d8dff0c657121c4db9fb392b9aabcc579f8deb8bfe17014a94403af36214876c19d4a2f0abd8285ede906669f5ab3b81d6844d
JWT_EXPIRES_IN=7d